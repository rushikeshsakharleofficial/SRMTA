# SRMTA Sub-Config: Queue & Retry Policy
# File: config.d/50-queue.yaml
# Tune queue behavior, retry schedules, and sharding independently

queue:
  spool_dir: "/var/spool/srmta"
  max_queue_depth: 500000
  max_retries: 9
  retry_intervals:
    - "5m"
    - "15m"
    - "30m"
    - "1h"
    - "2h"
    - "4h"
    - "8h"
    - "16h"
    - "24h"
  dead_letter_after: "72h"
  journal_enabled: true
  shard_count: 16
  domain_buckets: 256
  processing_workers: 50

bounce:
  hard_bounce_threshold: 0.05    # 5% — auto-pause sender
  soft_bounce_threshold: 0.15    # 15%
  complaint_threshold: 0.003     # 0.3%
  sender_pause_enabled: true
  suppression_list_enabled: true

rate_limit:
  global_rate: 500               # emails/sec globally
  per_domain_rate: 50            # emails/sec per domain
  per_sender_rate: 100           # emails/sec per sender
