# SRMTA Sender Domain → IP/Subnet Binding
# config.d/75-sender-routing.yaml
#
# Bind specific sender (FROM) domains to dedicated IPs or CIDR subnets.
# Sender routes take priority over MX-based routing (70-routing.yaml).
#
# Fields:
#   domain    — exact domain ("example.com") or wildcard ("*.example.com")
#   ips       — list of specific IP addresses for this sender domain
#   subnets   — list of CIDR ranges; pool IPs within these subnets are used
#   backup_ips — fallback IPs if all primaries are unhealthy
#
# Matching order: first match wins. Put more specific domains before wildcards.

routing:
  sender_routes:
    # ── Example: transactional mail from a dedicated subdomain ──────────
    # - domain: "notify.example.com"
    #   ips:
    #     - "203.0.113.40"

    # ── Example: all mail from example.com uses specific IPs ────────────
    # - domain: "example.com"
    #   ips:
    #     - "203.0.113.30"
    #     - "203.0.113.31"
    #   backup_ips:
    #     - "203.0.113.50"

    # ── Example: all subdomains of corp.com use a subnet ────────────────
    # - domain: "*.corp.com"
    #   subnets:
    #     - "10.0.1.0/24"
    #   backup_ips:
    #     - "203.0.113.50"

    # ── Example: marketing subdomain gets isolated IPs ──────────────────
    # - domain: "marketing.example.com"
    #   ips:
    #     - "203.0.113.42"
    #     - "203.0.113.43"
    #   subnets:
    #     - "198.51.100.0/28"
