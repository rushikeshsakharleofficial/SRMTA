# SRMTA Sub-Config: Database & Redis Credentials
# File: config.d/40-database.yaml
# Keep credentials separate from main config for security
# Use environment variables for secrets in production

database:
  # Driver: "postgres" (default) or "mysql" (for MySQL/MariaDB)
  driver: "${DB_DRIVER:postgres}"
  host: "${DB_HOST:localhost}"
  port: 5432                      # PostgreSQL: 5432, MySQL: 3306
  user: "${DB_USER:srmta}"
  password: "${DB_PASSWORD}"        # REQUIRED — must be set via environment variable
  dbname: "${DB_NAME:srmta}"
  ssl_mode: "require"              # PG: disable/require/verify-full; MySQL: true/false/skip-verify
  charset: "utf8mb4"              # MySQL only — ignored for PostgreSQL
  max_open_conns: 25
  max_idle_conns: 5

redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: "${REDIS_PASSWORD:}"
  db: 0
  pool_size: 10
