# SRMTA Provider Throttle Rules
# config.d/60-throttle.yaml
#
# Smart speed management per email provider. Each provider has different
# acceptance thresholds. These rules prevent blacklisting by respecting
# provider limits. Rates are automatically reduced on 4xx throttle responses.

throttle:
  # Default rule for unknown/unmatched providers
  defaults:
    max_connections: 10
    max_per_second: 20
    max_per_minute: 500
    max_per_hour: 10000
    max_recipients_conn: 100
    message_delay: "50ms"
    backoff_multiplier: 2.0
    max_backoff: "5m"

  providers:
    # ── Microsoft / Outlook ──────────────────────────────────────────
    # Outlook.com is very aggressive with rate limiting.
    # Keep connections low and spread messages slowly.
    - name: "microsoft"
      mx_patterns:
        - "*.mail.protection.outlook.com"
        - "*.olc.protection.outlook.com"
      domain_patterns:
        - "outlook.com"
        - "hotmail.com"
        - "live.com"
        - "msn.com"
        - "outlook.co.uk"
        - "hotmail.co.uk"
      max_connections: 5
      max_per_second: 3
      max_per_minute: 100
      max_per_hour: 2000
      max_recipients_conn: 10
      connection_delay: "2s"
      message_delay: "500ms"
      backoff_multiplier: 3.0
      max_backoff: "10m"

    # ── Google / Gmail ───────────────────────────────────────────────
    # Google is more tolerant but still throttles aggressively
    # when it detects spam patterns.
    - name: "google"
      mx_patterns:
        - "*.google.com"
        - "*.googlemail.com"
        - "gmail-smtp-in.l.google.com"
      domain_patterns:
        - "gmail.com"
        - "googlemail.com"
      max_connections: 10
      max_per_second: 10
      max_per_minute: 300
      max_per_hour: 5000
      max_recipients_conn: 50
      connection_delay: "500ms"
      message_delay: "100ms"
      backoff_multiplier: 2.5
      max_backoff: "8m"

    # ── Yahoo / AOL / Verizon Media ──────────────────────────────────
    - name: "yahoo"
      mx_patterns:
        - "*.yahoodns.net"
        - "*.yahoo.com"
      domain_patterns:
        - "yahoo.com"
        - "yahoo.co.uk"
        - "yahoo.co.in"
        - "aol.com"
        - "verizon.net"
      max_connections: 5
      max_per_second: 5
      max_per_minute: 150
      max_per_hour: 3000
      max_recipients_conn: 20
      connection_delay: "1s"
      message_delay: "300ms"
      backoff_multiplier: 2.0
      max_backoff: "10m"

    # ── Apple / iCloud ───────────────────────────────────────────────
    - name: "apple"
      mx_patterns:
        - "*.mail.icloud.com"
        - "*.apple.com"
      domain_patterns:
        - "icloud.com"
        - "me.com"
        - "mac.com"
      max_connections: 3
      max_per_second: 2
      max_per_minute: 60
      max_per_hour: 1000
      max_recipients_conn: 10
      connection_delay: "3s"
      message_delay: "500ms"
      backoff_multiplier: 3.0
      max_backoff: "15m"

    # ── Comcast / Xfinity ────────────────────────────────────────────
    - name: "comcast"
      mx_patterns:
        - "*.comcast.net"
      domain_patterns:
        - "comcast.net"
        - "xfinity.com"
      max_connections: 3
      max_per_second: 2
      max_per_minute: 50
      max_per_hour: 800
      max_recipients_conn: 10
      connection_delay: "5s"
      message_delay: "1s"
      backoff_multiplier: 3.0
      max_backoff: "15m"

    # ── Zoho Mail ────────────────────────────────────────────────────
    - name: "zoho"
      mx_patterns:
        - "*.zoho.com"
        - "*.zohomail.com"
      domain_patterns:
        - "zoho.com"
        - "zohomail.com"
        - "zohomail.in"
        - "zohomail.eu"
      max_connections: 5
      max_per_second: 5
      max_per_minute: 150
      max_per_hour: 3000
      max_recipients_conn: 20
      connection_delay: "1s"
      message_delay: "200ms"
      backoff_multiplier: 2.5
      max_backoff: "10m"

    # ── Generic Corporate (Office 365 hosted) ────────────────────────
    - name: "office365"
      mx_patterns:
        - "*.mail.protection.outlook.com"
      max_connections: 5
      max_per_second: 5
      max_per_minute: 150
      max_per_hour: 3000
      max_recipients_conn: 20
      connection_delay: "1s"
      message_delay: "200ms"
      backoff_multiplier: 2.0
      max_backoff: "10m"
