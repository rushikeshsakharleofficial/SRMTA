# SRMTA Sub-Config: SMTP Engine Settings
# File: config.d/10-smtp.yaml
# Loaded after main config.yaml, overrides SMTP-specific settings

smtp:
  inbound_addr: ":25"           # Incoming mail reception (MX)
  submission_addr: ":587"       # Authenticated submission (MSA)
  outbound_port: 25             # Remote port for outbound delivery
  max_connections: 2000
  max_message_size: 52428800    # 50MB
  read_timeout: "60s"
  write_timeout: "60s"
  max_recipients: 100
  require_auth: true
  require_tls: false
  banner_hostname: "mta1.example.com"
  allowed_domains:
    - "example.com"
    - "mail.example.com"
    - "transactional.example.com"
  enable_pipelining: true

delivery:
  max_concurrent: 500
  per_domain_concurrency: 20
  connection_timeout: "300s"
  dial_timeout: "30s"
  ehlo_timeout: "30s"
  mail_timeout: "30s"
  rcpt_timeout: "30s"
  data_timeout: "120s"
  pool_size: 50
  pool_idle_timeout: "60s"
