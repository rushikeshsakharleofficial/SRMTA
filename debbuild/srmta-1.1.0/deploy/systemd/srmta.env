# SRMTA environment variables
# Loaded by systemd EnvironmentFile= directive
# Edit this file to provide secrets without putting them in config.yaml
# IMPORTANT: Set strong, unique passwords before deployment!

# Database credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=srmta
DB_PASSWORD=              # REQUIRED — set a strong password before deployment
DB_NAME=srmta

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=           # REQUIRED — set a password for Redis

# API secrets
JWT_SECRET=               # REQUIRED — generate with: openssl rand -hex 32
WEBHOOK_SECRET=           # REQUIRED — generate with: openssl rand -hex 32
ALLOWED_ORIGINS=          # Comma-separated list of allowed CORS origins

# DKIM (if key paths use env vars)
# DKIM_KEY_DIR=/etc/srmta/dkim
