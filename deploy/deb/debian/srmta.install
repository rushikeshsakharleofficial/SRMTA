#!/usr/bin/dh-exec
# DEB install file — maps built files to their install paths

# Binary
srmta usr/sbin/

# Systemd units
deploy/systemd/srmta.service lib/systemd/system/
deploy/systemd/srmta.socket  lib/systemd/system/

# Configuration
configs/config.example.yaml etc/srmta/config.yaml
configs/config.d/           etc/srmta/config.d/
deploy/systemd/srmta.env    etc/srmta/

# Database migrations
migrations/ usr/share/srmta/migrations/
