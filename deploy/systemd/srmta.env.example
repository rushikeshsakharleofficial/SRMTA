# SRMTA environment variables example
# Copy this to srmta.env and fill in the values

# Database credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=srmta
DB_PASSWORD=              # REQUIRED — set a strong password
DB_NAME=srmta

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=           # REQUIRED — set a password

# API secrets
JWT_SECRET=               # REQUIRED — generate with: openssl rand -hex 32
WEBHOOK_SECRET=           # REQUIRED — generate with: openssl rand -hex 32
ALLOWED_ORIGINS=          # Comma-separated list

# DKIM
# DKIM_KEY_DIR=/etc/srmta/dkim
