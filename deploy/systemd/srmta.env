# SRMTA environment variables
# Loaded by systemd EnvironmentFile= directive
# Edit this file to provide secrets without putting them in config.yaml

# Database credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=srmta
DB_PASSWORD=changeme
DB_NAME=srmta

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# DKIM (if key paths use env vars)
# DKIM_KEY_DIR=/etc/srmta/dkim
